# ── LinkedIn scraping account ─────────────────────────────────
# Use a secondary/dummy account — not your main LinkedIn profile
SCRAPE_LINKEDIN_EMAIL=your_linkedin_email@example.com
SCRAPE_LINKEDIN_PASSWORD=your_linkedin_password

# ── AI API Keys ───────────────────────────────────────────────
# Gemini: https://aistudio.google.com/app/apikey  (free tier)
GEMINI_API_KEY=your_gemini_api_key

# Groq: https://console.groq.com/keys  (free tier)
GROQ_API_KEY=your_groq_api_key

# ── Gmail SMTP ────────────────────────────────────────────────
# Enable 2FA → myaccount.google.com → Security → App Passwords
SENDER_EMAIL=your_gmail@gmail.com
SMTP_APP_PASSWORD=xxxx xxxx xxxx xxxx
